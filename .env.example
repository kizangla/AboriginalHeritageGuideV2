# Database (PostgreSQL / Neon Serverless)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Google Maps API (for geocoding and Places API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mapbox (alternative geocoding / map tiles)
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Supply Nation (Indigenous business directory)
SUPPLY_NATION_USERNAME=your_supply_nation_username
SUPPLY_NATION_PASSWORD=your_supply_nation_password

# OpenAI (AI-generated cultural content)
OPENAI_API_KEY=your_openai_api_key

# CORS (optional — defaults to same-origin)
# CORS_ORIGIN=https://yourdomain.com
